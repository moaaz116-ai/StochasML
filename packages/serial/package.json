{
  "name": "@infera/serial",
  "version": "0.1.0",
  "description": "Binary serial protocol for Infera TinyML platform (COBS + CRC-8 + TLV)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/dom-serial": "^1.0.6",
    "@types/node": "^26.1.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  },
  "files": [
    "dist"
  ],
  "license": "Apache-2.0"
}
