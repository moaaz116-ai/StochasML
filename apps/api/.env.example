# Stochas ML Backend API Environment Variables (.env.example)

API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# SQLite or PostgreSQL database URL
DATABASE_URL=sqlite:///./data/stochas_ml.db

# Persistent artifact and firmware storage directory
STORAGE_DIR=./data/artifacts
LOG_LEVEL=INFO

# Security & Authentication
JWT_SECRET_KEY=replace-with-secure-64-char-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# SMTP Email Settings (Email Verification & Password Reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=moaz.abdellatif2009@gmail.com
SMTP_PASSWORD=your-app-password-here
EMAILS_FROM_EMAIL=moaz.abdellatif2009@gmail.com
EMAILS_FROM_NAME="Stochas ML Support"
