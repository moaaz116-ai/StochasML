# ==============================================================================
# Stochas ML — Production Environment Configuration (.env.example)
# Copy this file to .env before starting the application in production.
# ==============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# FRONTEND CONFIGURATION (Next.js 15)
# ──────────────────────────────────────────────────────────────────────────────
# Public API endpoint URL where the FastAPI backend is hosted.
# For local development: http://localhost:8000/api/v1
# For production: https://api.yourdomain.com/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Application name displayed in browser tabs and UI headers
NEXT_PUBLIC_APP_NAME="Stochas ML"

# Environment identifier (development | staging | production)
NEXT_PUBLIC_APP_ENV=production

# ──────────────────────────────────────────────────────────────────────────────
# BACKEND API CONFIGURATION (FastAPI)
# ──────────────────────────────────────────────────────────────────────────────
# Server binding host (0.0.0.0 binds to all network interfaces in container)
API_HOST=0.0.0.0
API_PORT=8000

# CORS Allowed Origins (Comma-separated list or * for local dev)
# Example production: https://stochasml.yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database URL (SQLite default for local/embedded production; Postgres supported)
# SQLite Example: sqlite:///./data/stochas_ml.db
# Postgres Example: postgresql://user:password@hostname:5432/stochas_ml
DATABASE_URL=sqlite:///./data/stochas_ml.db

# Storage directory for datasets, model artifacts, and firmware bundles
STORAGE_DIR=./data/artifacts

# Application Logging Level (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO

# ──────────────────────────────────────────────────────────────────────────────
# AUTHENTICATION & SECURITY (Production Required)
# ──────────────────────────────────────────────────────────────────────────────
# Secret key used for signing session tokens / JWTs
# Generate a secure random string using: openssl rand -hex 32
JWT_SECRET_KEY=replace-with-secure-64-char-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ──────────────────────────────────────────────────────────────────────────────
# EMAIL & VERIFICATION / PASSWORD RESET CONFIGURATION (SMTP)
# ──────────────────────────────────────────────────────────────────────────────
# Configure SMTP details to enable email verification and password reset emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=moaz.abdellatif2009@gmail.com
SMTP_PASSWORD=your-app-password-here
EMAILS_FROM_EMAIL=moaz.abdellatif2009@gmail.com
EMAILS_FROM_NAME="Stochas ML Support"

# ──────────────────────────────────────────────────────────────────────────────
# CELERY / REDIS BACKGROUND WORKERS (Optional for heavy asynchronous training)
# ──────────────────────────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0
